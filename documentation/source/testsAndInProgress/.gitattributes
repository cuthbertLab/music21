# Strip rendered image (.show()) outputs from these notebooks before they enter
# git history, so PR diffs stay small. Text/stream outputs are preserved.
# REQUIRES a one-time local setup (the command is intentionally NOT shared via
# .gitattributes, for security) -- see CONTRIBUTING.md / AGENTS.md:
#   git config filter.stripnbimage.clean \
#     "python documentation/source/testsAndInProgress/stripNotebookImages.py"
*-noimage.ipynb filter=stripnbimage
